{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "size": "Medium",
      "weight": "Bolder",
      "text": "{{SaveBoardLinkFormTitle}}",
      "horizontalAlignment": "Center",
      "wrap": true,
      "style": "heading"
    },
    {
      "type": "Input.Text",
      "id": "AzureDevOpsBoardUrl",
      "label": "Board URL",
      "isRequired": true,
      "errorMessage": "A valid Azure DevOps board URL is required",
      "value": "{{AzureDevOpsBoardUrlValue}}",
      "placeholder": "https://dev.azure.com/myorg/myproject/_boards/board/t/MyTeam/Backlog%20Items"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "{{SaveBoardLinkActionTitle}}",
      "data": {
        "id": "SaveBoardLinkAction"
      }
    }
  ]
}
